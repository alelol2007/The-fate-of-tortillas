<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/starry_galaxy_whatsapp_chat_2g56499w5vffbhiw">

    <TextView
        android:id="@+id/txt_quarters_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_quarters"
        android:textColor="@color/starlight_white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_crew_cards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/txt_quarters_title" />

    <Button
        android:id="@+id/btn_launch_mission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LAUNCH MISSION"
        android:textColor="@color/starlight_white"
        android:backgroundTint="#FF0000"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btn_view_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Crew Stats"
        android:backgroundTint="#4000D4FF"
        android:textColor="@color/starlight_white"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_launch_mission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>