<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/starry_galaxy_whatsapp_chat_2g56499w5vffbhiw"
    android:padding="16dp">

    <TextView
        android:id="@+id/txt_recruit_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECRUITMENT DESK"
        android:background="@color/blue_title"
        android:textColor="@color/starlight_white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/edt_crew_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Crew Name"
        android:padding="3px"
        android:background="@color/blue_title"
        android:textColorHint="#AAAAAA"
        android:textColor="@color/starlight_white"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/txt_recruit_title"/>

    <Spinner
        android:id="@+id/spinner_specialization"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="3px"
        android:background="@color/blue_title"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/starlight_white"
        app:layout_constraintTop_toBottomOf="@id/edt_crew_name"/>

    <Button
        android:id="@+id/btn_confirm_recruit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONFIRM RECRUIT"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/spinner_specialization"/>

</androidx.constraintlayout.widget.ConstraintLayout>