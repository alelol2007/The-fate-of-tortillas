<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/starry_galaxy_whatsapp_chat_2g56499w5vffbhiw"
    tools:context=".MissionActivity">

    <TextView
        android:id="@+id/txt_enemy_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACTIVE THREAT"
        android:textColor="#FF5555"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <include
        layout="@layout/item_character"
        android:id="@+id/card_enemy"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txt_enemy_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btn_attack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ATTACK!"
        android:textSize="24sp"
        android:backgroundTint="#FF0000"
        app:layout_constraintTop_toBottomOf="@id/card_enemy"
        app:layout_constraintBottom_toTopOf="@id/txt_squad_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_current_turn_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a card to select attacker"
        android:textColor="#00D4FF"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/btn_attack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txt_squad_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YOUR SQUAD"
        android:textColor="@color/starlight_white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layout_squad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layout_squad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <include
            layout="@layout/item_character"
            android:id="@+id/card_player_one"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <include
            layout="@layout/item_character"
            android:id="@+id/card_player_two"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>